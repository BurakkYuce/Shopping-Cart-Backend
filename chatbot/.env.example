# Database (same PostgreSQL instance as Spring Boot backend)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=chatbot_reader
DB_PASS=chatbot_reader_pass

# JWT — must match app.jwt.secret in Spring Boot application.yml
# Value is a Base64-encoded HMAC key (same as backend JWT_SECRET)
JWT_SECRET=ZGV2LXNlY3JldC1rZXktMzJjaGFycy1taW5pbXVtLXJlcXVpcmVk

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Limits
MAX_SQL_ROWS=500
SQL_RETRY_LIMIT=3

# Ports
CHAINLIT_PORT=8001
FASTAPI_PORT=8002
