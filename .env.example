# ========================
# PostgreSQL
# ========================
POSTGRES_USER=datapulse
POSTGRES_PASSWORD=<your-db-password>

# ========================
# JWT — Base64-encoded HMAC key (min 32 chars before encoding)
# Must match between Spring Boot and chatbot
# ========================
JWT_SECRET=<your-base64-encoded-jwt-secret>

# ========================
# Data Loading
# ========================
DATASETS_PATH=/datasets/output/
SEED_PASSWORD=<default-password-for-csv-seeded-users>

# ========================
# Elasticsearch
# ========================
ELASTIC_PASSWORD=<your-elastic-password>

# ========================
# LangGraph Chatbot — LLM provider ("openai" or "anthropic")
# ========================
LLM_PROVIDER=openai
OPENAI_API_KEY=<your-openai-api-key>
# ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ========================
# Mail (Mailtrap Sandbox for dev; swap host to SendGrid/SES for prod)
# ========================
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=<mailtrap-sandbox-username>
MAIL_PASSWORD=<mailtrap-sandbox-password>
MAIL_FROM=noreply@datapulse.test
MAIL_FROM_NAME=DataPulse
APP_BASE_URL=http://localhost:4200
