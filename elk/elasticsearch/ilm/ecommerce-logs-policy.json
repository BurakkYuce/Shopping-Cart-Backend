{
  "policy": {
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": {
          "rollover": {
            "max_age": "1d",
            "max_primary_shard_size": "5gb"
          },
          "set_priority": { "priority": 100 }
        }
      },
      "delete": {
        "min_age": "7d",
        "actions": { "delete": {} }
      }
    },
    "_meta": {
      "description": "Rollover daily or at 5GB. Delete after 7 days. Keeps disk bounded on demo/prod."
    }
  }
}
